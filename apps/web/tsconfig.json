{
  "extends": "@omnitower/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "paths": {
      "@/*": ["./apps/web/*"],
      "@omnitower/ui/*": ["./packages/ui/src/*"],
      "@api/*": ["./apps/api/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
