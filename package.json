{
  "name": "omnitower",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@omnitower/typescript-config": "workspace:*",
    "oxfmt": "^0.36.0",
    "turbo": "^2.8.8",
    "typescript": "catalog:dev"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.8",
  "catalog": {
    "better-auth": "^1.5.4",
    "drizzle-orm": "^0.45.1"
  },
  "catalogs": {
    "dev": {
      "typescript": "5.9.3",
      "@types/node": "^25.1.0"
    },
    "ui": {
      "@tailwindcss/postcss": "4.1.18",
      "tailwindcss": "4.1.18",
      "@types/react": "19.2.10",
      "@types/react-dom": "19.2.3",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@hugeicons/core-free-icons": "4.0.0",
      "@hugeicons/react": "1.1.5"
    }
  }
}
